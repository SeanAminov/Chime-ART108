  m_Script: {fileID: 11500000, guid: b67dc16dc9a1992469ff298a5deb6645, type: 3}
  m_Name: Level1_NaiEntry
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: We can collect them on the way up. It's what we do, right? Help where we
      can.
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: Stay close, {name}. This climb won't be easy.
