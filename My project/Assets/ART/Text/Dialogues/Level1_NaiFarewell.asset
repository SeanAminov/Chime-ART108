MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b67dc16dc9a1992469ff298a5deb6645, type: 3}
  m_Name: Level1_NaiFarewell
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: Wait, {name}. I can't cross this.
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: The bridge... it only lets the living pass. I've known that for a while.
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: But that's okay. You made it. That's what matters.
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: Go on. I'll find my own way.
