  m_Script: {fileID: 11500000, guid: b67dc16dc9a1992469ff298a5deb6645, type: 3}
  m_Name: Level1_KappaSuccess
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - speaker: Kappa
    portrait: {fileID: -8602144430665626385, guid: 4e7cf860bf46f4340aefa20455e25dae, type: 3}
    text: I can feel it... the water. It's filling back up.
  - speaker: Kappa
    portrait: {fileID: -8602144430665626385, guid: 4e7cf860bf46f4340aefa20455e25dae, type: 3}
    text: You actually came back!
  - speaker: Kappa
    portrait: {fileID: -8602144430665626385, guid: 4e7cf860bf46f4340aefa20455e25dae, type: 3}
    text: Thank you, {name}. Truly.
  - speaker: Kappa
    portrait: {fileID: -8602144430665626385, guid: 4e7cf860bf46f4340aefa20455e25dae, type: 3}
    text: The bridge ahead. I have enough strength now. Let me open it for you.
