  m_Script: {fileID: 11500000, guid: b67dc16dc9a1992469ff298a5deb6645, type: 3}
  m_Name: Level1_NaiLore
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: Over the centuries, I've guided people through the canyon. People used
      to fall pretty often.
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: 'But it''s been a long time since then. '
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: 'I suppose I shouldn''t be all that surprised that *you* fell, though. '
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: 'Sorry. I should''ve kept a better eye on you. '
