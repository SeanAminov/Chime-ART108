  m_Script: {fileID: 11500000, guid: b67dc16dc9a1992469ff298a5deb6645, type: 3}
  m_Name: Level1_RokuRoku
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - speaker: RokuRoku
    portrait: {fileID: -47630888937730442, guid: c7a19cbbf08b1bc4e8841b56d6caf9e9, type: 3}
    text: Oh. You again, {name}. Still climbing.
  - speaker: RokuRoku
    portrait: {fileID: -47630888937730442, guid: c7a19cbbf08b1bc4e8841b56d6caf9e9, type: 3}
    text: You know, the water up here doesn't sit where everyone can see it.
  - speaker: RokuRoku
    portrait: {fileID: -47630888937730442, guid: c7a19cbbf08b1bc4e8841b56d6caf9e9, type: 3}
    text: Good thing you have a friend who sees more than most.
