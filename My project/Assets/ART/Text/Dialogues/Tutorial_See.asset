  m_Script: {fileID: 11500000, guid: b67dc16dc9a1992469ff298a5deb6645, type: 3}
  m_Name: Tutorial_See
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: Oh! Are you not fully connected to my senses???
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: Hmmm....
  - speaker: Nai
    portrait: {fileID: -2997249256263405419, guid: 70cd6affe1cd26347b2a33cc24e58132, type: 3}
    text: It could be because of the fall. We won't be able to fully fix it until
      we get back up, but for now, hold Space to borrow my senses temporarily!
